{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.kembangseladang.com"
        }
      ],
      "destination": "https://kembangseladang.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|favicon.*|assets/|icons/|images/|logo.*|sw\\.js).*).*",
      "destination": "/index.html"
    }
  ]
}
